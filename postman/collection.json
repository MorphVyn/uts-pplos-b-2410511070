{
  "info": {
    "name": "UTS PPLOS — Sistem Pemesanan Tiket Event",
    "_postman_id": "uts-pplos-tiket-event",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",      "value": "http://localhost:8000" },
    { "key": "access_token",  "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "ticket_code",   "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var j = pm.response.json();",
                "  pm.collectionVariables.set('access_token', j.access_token);",
                "  pm.collectionVariables.set('refresh_token', j.refresh_token);",
                "  console.log('Token tersimpan!');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var j = pm.response.json();",
                "  pm.collectionVariables.set('access_token', j.access_token);",
                "  pm.collectionVariables.set('refresh_token', j.refresh_token);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/auth/logout"
          }
        },
        {
          "name": "Me (Profil)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/auth/me"
          }
        },
        {
          "name": "Google OAuth (buka di browser)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/google"
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List Events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/events?page=1&page_per=10",
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "page_per", "value": "10" },
                { "key": "search",   "value": "",   "disabled": true },
                { "key": "date",     "value": "",   "disabled": true }
              ]
            }
          }
        },
        {
          "name": "List Events — Filter by search",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/events?search=jazz&page=1&page_per=5",
              "query": [
                { "key": "search",   "value": "jazz" },
                { "key": "page",     "value": "1" },
                { "key": "page_per", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "List Events — Filter by date",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/events?date=2025-08-15",
              "query": [
                { "key": "date", "value": "2025-08-15" }
              ]
            }
          }
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/events/1"
          }
        },
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/api/events",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Konser Raisa 2025\",\n  \"description\": \"Konser solo Raisa di Jakarta\",\n  \"event_date\": \"2025-10-20\",\n  \"location\": \"Istora Senayan, Jakarta\",\n  \"poster_url\": null\n}"
            }
          }
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/api/events/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"location\": \"Gelora Bung Karno, Jakarta\"\n}"
            }
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/events/4"
          }
        }
      ]
    },
    {
      "name": "Ticket Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/events/1/categories"
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/events/1/categories/1"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/api/events/1/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"VVIP\",\n  \"price\": 2000000,\n  \"quota\": 50,\n  \"description\": \"Akses VVIP dengan fasilitas lengkap\"\n}"
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/api/events/1/categories/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 1750000,\n  \"quota\": 600\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/events/1/categories/3"
          }
        }
      ]
    },
    {
      "name": "Tickets & Checkout",
      "item": [
        {
          "name": "Checkout (Beli Tiket)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var j = pm.response.json();",
                "  if (j.tickets && j.tickets.length > 0) {",
                "    pm.collectionVariables.set('ticket_code', j.tickets[0].ticket_code);",
                "    console.log('Ticket code tersimpan: ' + j.tickets[0].ticket_code);",
                "  }",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/api/checkout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": 1,\n  \"category_id\": 1,\n  \"quantity\": 1\n}"
            }
          }
        },
        {
          "name": "My Tickets (List)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/tickets?page=1&per_page=10",
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "per_page", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Ticket by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/tickets/1"
          }
        },
        {
          "name": "Validate Ticket (Pintu Masuk)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/tickets/{{ticket_code}}/validate"
          }
        },
        {
          "name": "Validate Ticket — sudah dipakai (coba lagi)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/tickets/{{ticket_code}}/validate"
          }
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Tanpa Token (401)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/events"
          }
        },
        {
          "name": "Token Salah (401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer token_salah_ini" }],
            "url": "{{base_url}}/api/events"
          }
        },
        {
          "name": "Register — Email sudah ada (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login — Password Salah (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"passwordsalah\"\n}"
            }
          }
        },
        {
          "name": "Checkout — Stok Habis (409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{base_url}}/api/checkout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": 1,\n  \"category_id\": 2,\n  \"quantity\": 99999\n}"
            }
          }
        },
        {
          "name": "Get Event — Tidak Ada (404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/events/99999"
          }
        },
        {
          "name": "Register — Validasi Gagal (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bukan-email\"\n}"
            }
          }
        }
      ]
    }
  ]
}